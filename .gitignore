# Keep the ESGI theme and project plugin versioned.
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/woostarter/
!wp-content/themes/woostarter/**
!wp-content/plugins/
wp-content/plugins/*
!wp-content/plugins/store-temoignages/
!wp-content/plugins/store-temoignages/**

# Ignore runtime/generated WordPress content.
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/

data/
.env
